<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.evaluation.ServiceEvaluationMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.evaluation.ServiceEvaluation">
        <id column="evaluation_id" property="evaluationId"/>
        <result column="order_id" property="orderId"/>
        <result column="staff_id" property="staffId"/>
        <result column="provider_id" property="providerId"/>
        <result column="elder_id" property="elderId"/>
        <result column="attitude_score" property="attitudeScore"/>
        <result column="quality_score" property="qualityScore"/>
        <result column="efficiency_score" property="efficiencyScore"/>
        <result column="overall_score" property="overallScore"/>
        <result column="average_score" property="averageScore"/>
        <result column="evaluation_content" property="content"/>
        <result column="evaluation_tags" property="tags"/>
        <result column="is_anonymous" property="anonymous"/>
        <result column="evaluation_time" property="evaluationTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectEvaluationPage" resultMap="BaseResultMap">
        SELECT
            evaluation_id,
            order_id,
            staff_id,
            provider_id,
            elder_id,
            attitude_score,
            quality_score,
            efficiency_score,
            overall_score,
            average_score,
            evaluation_content,
            evaluation_tags,
            is_anonymous,
            evaluation_time,
            create_time
        FROM t_service_evaluation
        WHERE deleted = 0
        <if test="query.providerId != null and query.providerId != ''">
            AND provider_id = #{query.providerId}
        </if>
        <if test="query.staffId != null and query.staffId != ''">
            AND staff_id = #{query.staffId}
        </if>
        <if test="query.orderId != null and query.orderId != ''">
            AND order_id = #{query.orderId}
        </if>
        <if test="query.elderId != null and query.elderId != ''">
            AND elder_id = #{query.elderId}
        </if>
        <if test="query.startDate != null and query.startDate != ''">
            AND DATE(create_time) &gt;= #{query.startDate}
        </if>
        <if test="query.endDate != null and query.endDate != ''">
            AND DATE(create_time) &lt;= #{query.endDate}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
