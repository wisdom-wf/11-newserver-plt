<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.evaluation.CustomerFeedbackMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.evaluation.CustomerFeedback">
        <id column="feedback_id" property="feedbackId"/>
        <result column="feedback_type" property="feedbackType"/>
        <result column="elder_id" property="elderId"/>
        <result column="elder_name" property="elderName"/>
        <result column="elder_phone" property="elderPhone"/>
        <result column="staff_id" property="staffId"/>
        <result column="staff_name" property="staffName"/>
        <result column="provider_id" property="providerId"/>
        <result column="provider_name" property="providerName"/>
        <result column="order_id" property="orderId"/>
        <result column="content" property="content"/>
        <result column="photos" property="photos"/>
        <result column="handle_status" property="handleStatus"/>
        <result column="handler_id" property="handlerId"/>
        <result column="handler_name" property="handlerName"/>
        <result column="handling_result" property="handlingResult"/>
        <result column="handle_time" property="handleTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectFeedbackPage" resultMap="BaseResultMap">
        SELECT * FROM t_customer_feedback
        WHERE deleted = 0
        <if test="query.feedbackType != null and query.feedbackType != ''">
            AND feedback_type = #{query.feedbackType}
        </if>
        <if test="query.handleStatus != null and query.handleStatus != ''">
            AND handle_status = #{query.handleStatus}
        </if>
        <if test="query.providerId != null and query.providerId != ''">
            AND provider_id = #{query.providerId}
        </if>
        <if test="query.staffId != null and query.staffId != ''">
            AND staff_id = #{query.staffId}
        </if>
        <if test="query.elderId != null and query.elderId != ''">
            AND elder_id = #{query.elderId}
        </if>
        <if test="query.startDate != null and query.startDate != ''">
            AND DATE(create_time) &gt;= #{query.startDate}
        </if>
        <if test="query.endDate != null and query.endDate != ''">
            AND DATE(create_time) &lt;= #{query.endDate}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
