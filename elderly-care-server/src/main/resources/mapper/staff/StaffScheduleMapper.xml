<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.staff.StaffScheduleMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.staff.StaffSchedule">
        <id column="schedule_id" property="scheduleId"/>
        <result column="staff_id" property="staffId"/>
        <result column="schedule_date" property="scheduleDate"/>
        <result column="shift_type" property="shiftType"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="schedule_type" property="scheduleType"/>
        <result column="order_id" property="orderId"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="deleted" property="deleted"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByStaffId" resultMap="BaseResultMap">
        SELECT * FROM t_staff_schedule
        WHERE staff_id = #{staffId} AND deleted = 0
        ORDER BY schedule_date DESC, start_time ASC
    </select>

    <select id="selectByDate" resultMap="BaseResultMap">
        SELECT * FROM t_staff_schedule
        WHERE schedule_date = #{date} AND deleted = 0
        ORDER BY start_time ASC
    </select>

    <select id="selectSchedulePage" resultMap="BaseResultMap">
        SELECT * FROM t_staff_schedule
        WHERE deleted = 0
        <if test="query.staffId != null">
            AND staff_id = #{query.staffId}
        </if>
        <if test="query.date != null">
            AND schedule_date = #{query.date}
        </if>
        <if test="query.startDate != null">
            AND schedule_date &gt;= #{query.startDate}
        </if>
        <if test="query.endDate != null">
            AND schedule_date &lt;= #{query.endDate}
        </if>
        <if test="query.shiftType != null">
            AND shift_type = #{query.shiftType}
        </if>
        <if test="query.status != null">
            AND status = #{query.status}
        </if>
        ORDER BY schedule_date DESC, start_time ASC
    </select>

    <select id="selectByScheduleId" resultMap="BaseResultMap">
        SELECT * FROM t_staff_schedule
        WHERE schedule_id = #{scheduleId} AND deleted = 0
    </select>

</mapper>
