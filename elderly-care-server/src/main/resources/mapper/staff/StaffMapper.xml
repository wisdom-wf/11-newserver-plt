<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.staff.StaffMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.staff.Staff">
        <id column="staff_id" property="staffId"/>
        <result column="provider_id" property="providerId"/>
        <result column="provider_name" property="providerName"/>
        <result column="staff_no" property="staffNo"/>
        <result column="staff_name" property="staffName"/>
        <result column="gender" property="gender"/>
        <result column="birth_date" property="birthDate"/>
        <result column="age" property="age"/>
        <result column="id_card" property="idCard"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="address" property="address"/>
        <result column="nation" property="nation"/>
        <result column="political_status" property="politicalStatus"/>
        <result column="marital_status" property="maritalStatus"/>
        <result column="domicile_address" property="domicileAddress"/>
        <result column="residence_address" property="residenceAddress"/>
        <result column="emergency_contact" property="emergencyContact"/>
        <result column="emergency_phone" property="emergencyPhone"/>
        <result column="education" property="education"/>
        <result column="service_types" property="serviceTypes"/>
        <result column="photo_url" property="avatarUrl"/>
        <result column="status" property="status"/>
        <result column="work_status" property="workStatus"/>
        <result column="hire_date" property="hireDate"/>
        <result column="leave_date" property="leaveDate"/>
        <result column="leave_reason" property="leaveReason"/>
        <result column="audit_remark" property="auditRemark"/>
        <result column="deleted" property="deleted"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectStaffPage" resultMap="BaseResultMap">
        SELECT s.*, p.provider_name
        FROM t_staff s
        LEFT JOIN t_provider p ON s.provider_id = p.provider_id
        WHERE s.deleted = 0
        <if test="query.staffName != null and query.staffName != ''">
            AND s.staff_name LIKE CONCAT('%', #{query.staffName}, '%')
        </if>
        <if test="query.staffNo != null and query.staffNo != ''">
            AND s.staff_no = #{query.staffNo}
        </if>
        <if test="query.phone != null and query.phone != ''">
            AND s.phone = #{query.phone}
        </if>
        <if test="query.idCard != null and query.idCard != ''">
            AND s.id_card = #{query.idCard}
        </if>
        <if test="query.status != null">
            AND s.status = #{query.status}
        </if>
        <if test="query.providerId != null">
            AND s.provider_id = #{query.providerId}
        </if>
        <if test="query.serviceType != null and query.serviceType != ''">
            AND s.service_types LIKE CONCAT('%', #{query.serviceType}, '%')
        </if>
        <if test="query.hireDateStart != null">
            AND s.hire_date &gt;= #{query.hireDateStart}
        </if>
        <if test="query.hireDateEnd != null">
            AND s.hire_date &lt;= #{query.hireDateEnd}
        </if>
        ORDER BY s.create_time DESC
    </select>

    <select id="selectStaffById" resultMap="BaseResultMap">
        SELECT s.*, p.provider_name
        FROM t_staff s
        LEFT JOIN t_provider p ON s.provider_id = p.provider_id
        WHERE s.staff_id = #{staffId} AND s.deleted = 0
    </select>

    <update id="updateStaffById">
        UPDATE t_staff
        <set>
            <if test="staffName != null">staff_name = #{staffName},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="age != null">age = #{age},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="nation != null">nation = #{nation},</if>
            <if test="education != null">education = #{education},</if>
            <if test="politicalStatus != null">political_status = #{politicalStatus},</if>
            <if test="maritalStatus != null">marital_status = #{maritalStatus},</if>
            <if test="domicileAddress != null">domicile_address = #{domicileAddress},</if>
            <if test="residenceAddress != null">residence_address = #{residenceAddress},</if>
            <if test="emergencyContact != null">emergency_contact = #{emergencyContact},</if>
            <if test="emergencyPhone != null">emergency_phone = #{emergencyPhone},</if>
            <if test="serviceTypes != null">service_types = #{serviceTypes},</if>
            <if test="hireDate != null">hire_date = #{hireDate},</if>
            <if test="leaveDate != null">leave_date = #{leaveDate},</if>
            <if test="leaveReason != null">leave_reason = #{leaveReason},</if>
            <if test="avatarUrl != null">photo_url = #{avatarUrl},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE staff_id = #{staffId}
    </update>

</mapper>
