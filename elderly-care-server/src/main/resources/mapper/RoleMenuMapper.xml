<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.RoleMenuMapper">

    <delete id="deleteByRoleId">
        DELETE FROM t_role_menu WHERE role_id = #{roleId}
    </delete>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO t_role_menu (role_menu_id, role_id, menu_id, create_time) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.roleMenuId}, #{item.roleId}, #{item.menuId}, NOW())
        </foreach>
    </insert>

    <select id="selectByRoleId" resultType="com.elderlycare.entity.RoleMenu">
        SELECT * FROM t_role_menu WHERE role_id = #{roleId}
    </select>

</mapper>
