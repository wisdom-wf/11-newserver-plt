<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.financial.SettlementMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.financial.Settlement">
        <id column="settlement_id" property="settlementId"/>
        <result column="settlement_no" property="settlementNo"/>
        <result column="provider_id" property="providerId"/>
        <result column="staff_id" property="staffId"/>
        <result column="total_amount" property="totalServiceAmount"/>
        <result column="subsidy_amount" property="totalSubsidyAmount"/>
        <result column="self_pay_amount" property="totalSelfPayAmount"/>
        <result column="payment_status" property="status"/>
        <result column="payment_time" property="confirmTime"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectSettlementPage" resultMap="BaseResultMap">
        SELECT
            st.settlement_id,
            st.settlement_no,
            st.provider_id,
            p.provider_name AS providerName,
            st.staff_id,
            s.staff_name AS staffName,
            st.total_amount,
            st.subsidy_amount,
            st.self_pay_amount,
            st.payment_status,
            st.payment_time,
            st.create_time
        FROM t_settlement st
        LEFT JOIN t_provider p ON st.provider_id = p.provider_id
        LEFT JOIN t_staff s ON st.staff_id = s.staff_id
        WHERE 1=1
        <if test="query.settlementNo != null and query.settlementNo != ''">
            AND st.settlement_no LIKE CONCAT('%', #{query.settlementNo}, '%')
        </if>
        <if test="query.providerId != null and query.providerId != ''">
            AND st.provider_id = #{query.providerId}
        </if>
        <if test="query.staffId != null and query.staffId != ''">
            AND st.staff_id = #{query.staffId}
        </if>
        <if test="query.status != null and query.status != ''">
            AND st.payment_status = #{query.status}
        </if>
        ORDER BY st.create_time DESC
    </select>

</mapper>
