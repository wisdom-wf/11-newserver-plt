<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.elder.ElderMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.elder.Elder">
        <id column="elder_id" property="elderId"/>
        <result column="elder_name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="birth_date" property="birthDate"/>
        <result column="age" property="age"/>
        <result column="id_card" property="idCard"/>
        <result column="phone" property="phone"/>
        <result column="ethnicity" property="ethnicity"/>
        <result column="education" property="education"/>
        <result column="marital_status" property="maritalStatus"/>
        <result column="political_status" property="politicalStatus"/>
        <result column="photo_url" property="photoUrl"/>
        <result column="status" property="status"/>
        <result column="register_date" property="registerDate"/>
        <result column="address" property="address"/>
        <result column="area_id" property="areaId"/>
        <result column="care_level" property="careLevel"/>
        <result column="living_status" property="livingStatus"/>
        <result column="health_status" property="healthStatus"/>
        <result column="care_type" property="careType"/>
        <result column="emergency_contact" property="emergencyContact"/>
        <result column="emergency_phone" property="emergencyPhone"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <resultMap id="ElderAreaResultMap" type="com.elderlycare.entity.elder.Elder">
        <id column="elder_id" property="elderId"/>
        <result column="elder_name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="birth_date" property="birthDate"/>
        <result column="age" property="age"/>
        <result column="id_card" property="idCard"/>
        <result column="phone" property="phone"/>
        <result column="ethnicity" property="ethnicity"/>
        <result column="education" property="education"/>
        <result column="marital_status" property="maritalStatus"/>
        <result column="political_status" property="politicalStatus"/>
        <result column="photo_url" property="photoUrl"/>
        <result column="status" property="status"/>
        <result column="register_date" property="registerDate"/>
        <result column="address" property="address"/>
        <result column="area_id" property="areaId"/>
        <result column="care_level" property="careLevel"/>
        <result column="living_status" property="livingStatus"/>
        <result column="health_status" property="healthStatus"/>
        <result column="care_type" property="careType"/>
        <result column="emergency_contact" property="emergencyContact"/>
        <result column="emergency_phone" property="emergencyPhone"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
        <result column="area_name" property="areaName"/>
        <result column="provider_id" property="providerId"/>
        <result column="provider_name" property="providerName"/>
    </resultMap>

    <select id="selectByIdCard" resultMap="BaseResultMap">
        SELECT * FROM t_elder WHERE id_card = #{idCard} AND deleted = 0 LIMIT 1
    </select>

    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT * FROM t_elder WHERE phone = #{phone} AND deleted = 0 LIMIT 1
    </select>

    <select id="selectElderPage" resultMap="ElderAreaResultMap">
        SELECT e.elder_id, e.elder_name, e.gender, e.birth_date, e.age, e.id_card, e.phone,
               e.ethnicity, e.education, e.marital_status, e.political_status, e.photo_url,
               e.status, e.register_date, e.address, e.area_id, e.care_level, e.living_status,
               e.health_status, e.care_type, e.emergency_contact, e.emergency_phone,
               e.create_time, e.update_time, e.deleted, e.provider_id,
               a.area_name, p.provider_name
        FROM t_elder e
        LEFT JOIN t_area a ON e.area_id = a.area_id
        LEFT JOIN t_provider p ON e.provider_id = p.provider_id
        WHERE e.deleted = 0
        <if test="dto.name != null and dto.name != ''">
            AND e.elder_name LIKE CONCAT('%', #{dto.name}, '%')
        </if>
        <if test="dto.idCard != null and dto.idCard != ''">
            AND e.id_card = #{dto.idCard}
        </if>
        <if test="dto.phone != null and dto.phone != ''">
            AND e.phone = #{dto.phone}
        </if>
        <if test="dto.status != null">
            AND e.status = #{dto.status}
        </if>
        <if test="dto.careLevel != null">
            AND e.care_level = #{dto.careLevel}
        </if>
        <if test="dto.careType != null and dto.careType != ''">
            AND e.care_type = #{dto.careType}
        </if>
        <if test="dto.providerId != null and dto.providerId != ''">
            AND e.provider_id = #{dto.providerId}
        </if>
        ORDER BY e.create_time DESC
    </select>

</mapper>
