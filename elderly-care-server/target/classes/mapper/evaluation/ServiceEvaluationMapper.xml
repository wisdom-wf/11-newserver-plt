<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.evaluation.ServiceEvaluationMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.evaluation.ServiceEvaluation">
        <id column="evaluation_id" property="evaluationId"/>
        <result column="order_id" property="orderId"/>
        <result column="staff_id" property="staffId"/>
        <result column="staff_name" property="staffName"/>
        <result column="provider_id" property="providerId"/>
        <result column="provider_name" property="providerName"/>
        <result column="elder_id" property="elderId"/>
        <result column="elder_name" property="elderName"/>
        <result column="service_type_code" property="serviceTypeCode"/>
        <result column="service_type_name" property="serviceTypeName"/>
        <result column="rating" property="rating"/>
        <result column="attitude_score" property="attitudeScore"/>
        <result column="quality_score" property="qualityScore"/>
        <result column="efficiency_score" property="efficiencyScore"/>
        <result column="content" property="content"/>
        <result column="tags" property="tags"/>
        <result column="anonymous" property="anonymous"/>
        <result column="status" property="status"/>
        <result column="reply_content" property="replyContent"/>
        <result column="reply_time" property="replyTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectEvaluationPage" resultMap="BaseResultMap">
        SELECT * FROM t_service_evaluation
        WHERE deleted = 0
        <if test="query.providerId != null and query.providerId != ''">
            AND provider_id = #{query.providerId}
        </if>
        <if test="query.staffId != null and query.staffId != ''">
            AND staff_id = #{query.staffId}
        </if>
        <if test="query.orderId != null and query.orderId != ''">
            AND order_id = #{query.orderId}
        </if>
        <if test="query.elderId != null and query.elderId != ''">
            AND elder_id = #{query.elderId}
        </if>
        <if test="query.serviceTypeCode != null and query.serviceTypeCode != ''">
            AND service_type_code = #{query.serviceTypeCode}
        </if>
        <if test="query.minRating != null">
            AND rating &gt;= #{query.minRating}
        </if>
        <if test="query.maxRating != null">
            AND rating &lt;= #{query.maxRating}
        </if>
        <if test="query.startDate != null and query.startDate != ''">
            AND DATE(create_time) &gt;= #{query.startDate}
        </if>
        <if test="query.endDate != null and query.endDate != ''">
            AND DATE(create_time) &lt;= #{query.endDate}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
