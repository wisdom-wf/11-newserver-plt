<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderlycare.mapper.order.ServiceRecordMapper">

    <resultMap id="BaseResultMap" type="com.elderlycare.entity.order.ServiceRecord">
        <id column="service_record_id" property="serviceRecordId"/>
        <result column="order_id" property="orderId"/>
        <result column="staff_id" property="staffId"/>
        <result column="check_in_time" property="checkInTime"/>
        <result column="check_out_time" property="checkOutTime"/>
        <result column="service_duration" property="serviceDuration"/>
        <result column="check_in_location" property="checkInLocation"/>
        <result column="check_out_location" property="checkOutLocation"/>
        <result column="service_photos" property="servicePhotos"/>
        <result column="service_video" property="serviceVideo"/>
        <result column="service_log" property="serviceLog"/>
        <result column="abnormal_situation" property="abnormalSituation"/>
        <result column="elder_signature" property="elderSignature"/>
        <result column="service_status" property="serviceStatus"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectServiceRecordPage" resultMap="BaseResultMap">
        SELECT sr.* FROM t_service_record sr
        LEFT JOIN t_order o ON sr.order_id = o.order_id
        WHERE 1=1
        <if test="query.staffId != null and query.staffId != ''">
            AND sr.staff_id = #{query.staffId}
        </if>
        <if test="query.startDate != null">
            AND DATE(sr.check_in_time) >= #{query.startDate}
        </if>
        <if test="query.endDate != null">
            AND DATE(sr.check_in_time) &lt;= #{query.endDate}
        </if>
        <if test="query.orderId != null and query.orderId != ''">
            AND sr.order_id = #{query.orderId}
        </if>
        ORDER BY sr.create_time DESC
    </select>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT * FROM t_service_record
        WHERE order_id = #{orderId}
        LIMIT 1
    </select>

</mapper>
